# Discord bot token from Discord Developer Portal.
# If /home/deepanshu/config/shared.secrets.env already has DISCORD_BOT_TOKEN, omit this.
DISCORD_BOT_TOKEN=

# Dedicated receipt channel ID. Enable Discord developer mode, right-click channel, Copy ID.
RECEIPT_CHANNEL_ID=

# OpenAI API key and models.
# If /home/deepanshu/config/shared.secrets.env already has OPENAI_API_KEY, omit this.
OPENAI_API_KEY=
OPENAI_RECEIPT_MODEL=gpt-4o-mini
OPENAI_CORRECTION_MODEL=gpt-4o-mini

# Local storage
DATABASE_PATH=data/expenses.sqlite
IMAGE_DIR=data/images
MAX_IMAGE_BYTES=8388608
DEFAULT_CURRENCY=THB
